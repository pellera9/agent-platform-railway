# ---------------------------------------------------------------------------
# Required — OpenAI powers every agent and embeddings
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Runtime — compose sets local dev defaults. Override only outside compose.
# ---------------------------------------------------------------------------
# RUNTIME_ENV=prd
# AGNO_DEBUG=False
# WAIT_FOR_DB=False

# ---------------------------------------------------------------------------
# Production — JWT verification for AgentOS RBAC.
# AgentOS enables RBAC whenever RUNTIME_ENV=prd (the default outside dev).
# Without JWT_VERIFICATION_KEY or JWT_JWKS_FILE, prod refuses to serve traffic.
# Generate the keypair at os.agno.com (Connect OS → Live, name it Live Agent
# Platform, then Settings → OS & Security → Token-Based Authorization (JWT)).
# During ./scripts/railway/up.sh, the script pauses after creating the Railway
# domain so you can paste the full PEM block into the prompt; it writes the key
# here. Or mount a JWKS file and set JWT_JWKS_FILE.
# Set `authorization=False` in app/main.py to opt out (not recommended).
# ---------------------------------------------------------------------------
# JWT_VERIFICATION_KEY=-----BEGIN PUBLIC KEY-----
# MIIBIjANBgkq...
# -----END PUBLIC KEY-----
# JWT_JWKS_FILE=/app/jwks.json

# ---------------------------------------------------------------------------
# AgentOS scheduler base URL. Defaults to http://127.0.0.1:8000 for local development.
# When AgentOS is deployed to a different domain, set this to the public URL.
# ---------------------------------------------------------------------------
# AGENTOS_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Web search — WebSearch Agent uses Parallel's MCP server.
#   PARALLEL_API_KEY set  →  authenticated /mcp endpoint (higher rate ceiling)
#   unset                 →  keyless /mcp endpoint (good for dev)
# ---------------------------------------------------------------------------
# PARALLEL_API_KEY=

# ---------------------------------------------------------------------------
# Scheduler — a reference workflow (workflows/deployment_check.py) fired on a
# cron by app/schedules.py. It checks deployment wiring and returns a readiness
# report. Set ENABLE_DEPLOY_CHECK=False to disable it.
# ---------------------------------------------------------------------------
# ENABLE_DEPLOY_CHECK=False

# ---------------------------------------------------------------------------
# Slack — set both to enable the Slack interface.
#   SLACK_BOT_TOKEN       Bot User OAuth Token (xoxb-***)
#   SLACK_SIGNING_SECRET  Signing Secret (Basic Information → App Credentials)
# ---------------------------------------------------------------------------
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Database — defaults match docker compose
# ---------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
# DB_DRIVER=postgresql+psycopg

# ---------------------------------------------------------------------------
# Optional — alternate model providers
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
